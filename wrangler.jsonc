{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "borderless-hackathon",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "hackathon.borderlesscoding.com", "custom_domain": true }
  ]
}
